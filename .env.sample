# ============================================================
# Intercept ADS-B PostgreSQL connection
# ============================================================

INTERCEPT_ADSB_DB_HOST=localhost
INTERCEPT_ADSB_DB_PORT=5432
INTERCEPT_ADSB_DB_NAME=intercept_adsb
INTERCEPT_ADSB_DB_USER=intercept
INTERCEPT_ADSB_DB_PASSWORD=change_me


# ============================================================
# Output behavior
# ============================================================

# Directory where exported aircraft JSON files will be written
AIRCRAFT_OUTPUT_DIR=./adsb_exports

# Prefix for rotated session files
# Example: aircraft_20260510_120000Z.json
AIRCRAFT_FILE_PREFIX=aircraft

# How often to refresh/write the output file
AIRCRAFT_REFRESH_SECONDS=1

# Only include aircraft seen within the last N seconds
AIRCRAFT_MAX_AGE_SECONDS=60

# Timezone for interpreting --date values (IANA name, e.g. America/New_York)
# Defaults to UTC if unset
AIRCRAFT_TIMEZONE=UTC

# Start a new output file every X minutes
# Examples:
#   5  = new file every 5 minutes
#   15 = new file every 15 minutes
#   60 = new file every hour
AIRCRAFT_SESSION_MINUTES=15


# ============================================================
# Live aircraft.json behavior
# ============================================================

# Also maintain a live/latest aircraft.json file
# Useful if nginx/tar1090/readsb-style tools expect:
# /data/aircraft.json
AIRCRAFT_WRITE_LATEST=true

# Name of the live/latest file inside AIRCRAFT_OUTPUT_DIR
AIRCRAFT_LATEST_FILE=aircraft.json